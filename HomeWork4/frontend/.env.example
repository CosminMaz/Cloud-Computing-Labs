# Copy this file to `.env` and fill in real values. Never commit `.env`.
# Vite bakes these into the bundle at build time — restart `npm run dev` after editing.

# ── Microsoft Entra External ID (CIAM) ─────────────────────
VITE_ENTRA_CLIENT_ID=
VITE_ENTRA_TENANT_ID=
VITE_ENTRA_AUTHORITY=https://<your-tenant>.ciamlogin.com/<your-tenant>.onmicrosoft.com

# ── Backend API ────────────────────────────────────────────
VITE_API_URL=http://localhost:8000

# ── Azure Bot Service Web Chat (FAQ chatbot) ───────────────
# Portal → Azure Bot resource → Channels → Web Chat → "Embed code".
# Format: https://webchat.botframework.com/embed/<bot-name>?s=<direct-line-secret>
# Leave empty to hide the chat panel on contractor profiles.
VITE_BOT_WEBCHAT_URL=
