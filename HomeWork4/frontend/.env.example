# Copy this file to `.env` and fill in real values. Never commit `.env`.
# Vite bakes these into the bundle at build time — restart `npm run dev` after editing.

# ── Microsoft Entra External ID (CIAM) ─────────────────────
VITE_ENTRA_CLIENT_ID=
VITE_ENTRA_TENANT_ID=
VITE_ENTRA_AUTHORITY=https://<your-tenant>.ciamlogin.com/<your-tenant>.onmicrosoft.com

# ── Backend API ────────────────────────────────────────────
# The chat panel on contractor profiles hits POST /api/chat/ask, which the
# backend proxies to Custom Question Answering. No frontend secret required.
VITE_API_URL=http://localhost:8000
