# Copy this file to `.env` and fill in real values. Never commit `.env`.

# ── Microsoft Entra External ID (CIAM) ─────────────────────
ENTRA_CLIENT_ID=
ENTRA_TENANT_ID=
ENTRA_AUTHORITY=https://<your-tenant>.ciamlogin.com/<your-tenant>.onmicrosoft.com

# ── App ────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ── Azure SQL Database ─────────────────────────────────────
# Driver "ODBC Driver 18 for SQL Server" must be installed locally.
DATABASE_URL="mssql+pyodbc://<user>:<password>@<server>.database.windows.net:1433/<db>?driver=ODBC+Driver+18+for+SQL+Server"

# ── Azure Blob Storage (profile pictures) ──────────────────
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=profile-pictures

# ── Azure Service Bus (booking events) ─────────────────────
# Backend only needs Send rights on the queue; "RootManageSharedAccessKey" works for the lab.
AZURE_SERVICE_BUS_CONNECTION_STRING=
AZURE_SERVICE_BUS_QUEUE=booking-events
