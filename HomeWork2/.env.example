# PostgreSQL
POSTGRES_DB=winamp
POSTGRES_USER=winamp
POSTGRES_PASSWORD=change_me

# Connection URLs
GINGO_DATABASE_URL=postgres://winamp:change_me@postgres:5432/winamp?sslmode=disable
JAVANILLA_DATABASE_URL=jdbc:postgresql://postgres:5432/winamp?user=winamp&password=change_me&sslmode=disable
RECOMMENDER_DATABASE_URL=postgres://winamp:change_me@postgres:5432/winamp?sslmode=disable

# Auth
JWT_SECRET=change_me_use_a_long_random_string

# Middleware
PORT=9000
FRONTEND_ORIGIN=http://localhost:5173
GO_SERVICE_URL=http://gingo:8080
JAVA_SERVICE_URL=http://javanilla:8000
THIRD_SERVICE_URL=http://third-service:7000
